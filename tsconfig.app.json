{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    // Extra safety for array and object lookups, but may have false positives.
    "noUncheckedIndexedAccess": true,

    // Path mapping for cleaner imports.
    "paths": {
      "@/*": ["./src/*"]
    },

    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking.
    // Specified here to keep it out of the root directory.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    // Strict type-checking options.
    "strict": true,

    // Enforce that all variables are used, which helps catch unused code and potential bugs.
    "noUnusedLocals": true,

    // Enforce that all function parameters are used, which helps catch unused code and potential bugs.
    "noUnusedParameters": true,

    // Enforce that switch statements have a default case or all possible cases are handled.
    "noFallthroughCasesInSwitch": true,

    // Enforce consistent casing in file names to avoid issues on case-sensitive file systems.
    "forceConsistentCasingInFileNames": true,
  }
}
